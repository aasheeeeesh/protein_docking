title       = NVT equilibration
define      = -DPOSRES

integrator  = md
nsteps      = 50000     ; 100 ps
dt          = 0.002

tcoupl      = Nose-Hoover
tc-grps     = Protein Water_and_ions
tau_t       = 0.5 0.5
ref_t       = 318 318

pcoupl      = no

constraints = h-bonds
constraint_algorithm = lincs

cutoff-scheme = Verlet
ns_type     = grid
rlist       = 1.0
rcoulomb    = 1.0
rvdw        = 1.0

pbc         = xyz
