title       = NPT equilibration
define      = -DPOSRES

integrator  = md
nsteps      = 50000
dt          = 0.002

tcoupl      = Nose-Hoover
tc-grps     = Protein Water_and_ions
tau_t       = 0.5 0.5
ref_t       = 318 318

pcoupl      = Parrinello-Rahman
pcoupltype  = isotropic
tau_p       = 2.0
ref_p       = 1.0
compressibility = 4.5e-5

constraints = h-bonds
constraint_algorithm = lincs

cutoff-scheme = Verlet
rlist       = 1.0
rcoulomb    = 1.0
rvdw        = 1.0

pbc         = xyz
